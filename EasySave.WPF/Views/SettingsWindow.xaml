<Window x:Class="EasySave.WPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding L[settings.title]}" Height="680" Width="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F0F4F0">

    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2E7D32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1B5E20"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>
        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="BorderBrush" Value="#A5D6A7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B5E20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2E7D32"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#2E7D32"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8F5E9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#C62828"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B71C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#A5D6A7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8E6C9"/>
                    <Setter Property="Foreground" Value="#1B5E20"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F5E9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="9,7"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="56"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1B5E20">
            <TextBlock Text="{Binding L[settings.title]}" Foreground="White"
                       FontSize="15" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="20,0"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="22,6">
            <StackPanel>

                <!-- GENERAL -->
                <TextBlock Text="{Binding L[settings.section.general]}" Style="{StaticResource SectionTitle}"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding L[settings.language]}" Style="{StaticResource FormLabel}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Background="White" BorderBrush="#A5D6A7"
                              Padding="9,7" FontSize="12" SelectedValue="{Binding Language}" SelectedValuePath="Content">
                        <ComboBoxItem Content="en"/>
                        <ComboBoxItem Content="fr"/>
                    </ComboBox>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding L[settings.log.format]}" Style="{StaticResource FormLabel}"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" Background="White" BorderBrush="#A5D6A7"
                              Padding="9,7" FontSize="12" SelectedValue="{Binding LogFormat}" SelectedValuePath="Content">
                        <ComboBoxItem Content="JSON"/>
                        <ComboBoxItem Content="XML"/>
                    </ComboBox>
                </Grid>

                <!-- SECURITY -->
                <TextBlock Text="{Binding L[settings.section.security]}" Style="{StaticResource SectionTitle}"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding L[settings.crypto.path]}" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource FormTextBox}"
                             Text="{Binding CryptoSoftPath, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding L[settings.business.software]}" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource FormTextBox}"
                             Text="{Binding BusinessSoftwareName, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <!-- ENCRYPTED EXTENSIONS -->
                <TextBlock Text="{Binding L[settings.extensions]}" Style="{StaticResource SectionTitle}"/>
                <ListBox x:Name="ExtListBox" ItemsSource="{Binding EncryptedExtensions}" Height="75" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource FormTextBox}" x:Name="NewExtBox"
                             Text="{Binding NewExtension, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="2" Content="{Binding L[btn.add]}" Style="{StaticResource SecondaryButton}"
                            Command="{Binding AddExtensionCommand}"/>
                    <Button Grid.Column="4" Content="{Binding L[btn.delete]}" Style="{StaticResource DangerButton}"
                            Command="{Binding RemoveExtensionCommand}"
                            CommandParameter="{Binding SelectedItem, ElementName=ExtListBox}"/>
                </Grid>

                <!-- PRIORITY EXTENSIONS (NEW v3.0) -->
                <TextBlock Text="{Binding L[settings.priority.extensions]}" Style="{StaticResource SectionTitle}"/>
                <ListBox x:Name="PrioListBox" ItemsSource="{Binding PriorityExtensions}" Height="75" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource FormTextBox}"
                             Text="{Binding NewPriorityExtension, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="2" Content="{Binding L[btn.add]}" Style="{StaticResource SecondaryButton}"
                            Command="{Binding AddPriorityExtensionCommand}"/>
                    <Button Grid.Column="4" Content="{Binding L[btn.delete]}" Style="{StaticResource DangerButton}"
                            Command="{Binding RemovePriorityExtensionCommand}"
                            CommandParameter="{Binding SelectedItem, ElementName=PrioListBox}"/>
                </Grid>

                <!-- PARALLEL TRANSFERS (NEW v3.0) -->
                <TextBlock Text="{Binding L[settings.section.parallel]}" Style="{StaticResource SectionTitle}"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding L[settings.max.file.size]}" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Column="1" Style="{StaticResource FormTextBox}"
                             Text="{Binding MaxParallelFileSizeKb, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
                <TextBlock Foreground="#888780" FontSize="11" Margin="0,0,0,4"
                           Text="{Binding L[settings.hint.parallel]}"/>

                <!-- LOG CENTRALISATION (NEW v3.0) -->
                <TextBlock Text="{Binding L[settings.section.log.docker]}" Style="{StaticResource SectionTitle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding L[settings.log.storage.mode]}" Style="{StaticResource FormLabel}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Background="White" BorderBrush="#A5D6A7"
                              Padding="9,7" FontSize="12" SelectedValue="{Binding LogStorageMode}" SelectedValuePath="Content">
                        <ComboBoxItem Content="Local"/>
                        <ComboBoxItem Content="Remote"/>
                        <ComboBoxItem Content="Both"/>
                    </ComboBox>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding L[settings.log.server.url]}" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource FormTextBox}"
                             Text="{Binding LogServerUrl, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
                <TextBlock Foreground="#888780" FontSize="11" Margin="0,6,0,8"
                           Text="{Binding L[settings.hint.log.server]}"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="#C8E6C9" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="20,0">
                <Button Content="{Binding L[btn.save]}" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveSettingsCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
