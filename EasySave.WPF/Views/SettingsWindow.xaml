<Window x:Class="EasySave.WPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="460" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="160"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<ComboBox Grid.Row="0" Grid.Column="1"
          SelectedValue="{Binding Language}"
          SelectedValuePath="Content"
          Margin="0,2">
			<ComboBoxItem Content="en"/>
			<ComboBoxItem Content="fr"/>
		</ComboBox>

		<ComboBox Grid.Row="1" Grid.Column="1"
				  SelectedValue="{Binding LogFormat}"
				  SelectedValuePath="Content"
				  Margin="0,2">
			<ComboBoxItem Content="JSON"/>
			<ComboBoxItem Content="XML"/>
		</ComboBox>

		<Label Grid.Row="2" Content="Business software:"/>
		<TextBox Grid.Row="2" Grid.Column="1" Text="{Binding BusinessSoftwareName, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>

		<Label Grid.Row="3" Content="CryptoSoft path:"/>
		<TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CryptoSoftPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>

		<Label Grid.Row="4" Grid.ColumnSpan="2" Content="Encrypted extensions:" Margin="0,8,0,4"/>

		<Grid Grid.Row="5" Grid.ColumnSpan="2">
			<Grid.RowDefinitions>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<ListBox Grid.Row="0" ItemsSource="{Binding EncryptedExtensions}" Margin="0,0,0,4"/>

			<Grid Grid.Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<Grid Grid.Column="0" Margin="0,0,4,0">
					<TextBox x:Name="NewExtTextBox" Text="{Binding NewExtension, UpdateSourceTrigger=PropertyChanged}" />

					<TextBlock Text=".pdf"
                               Foreground="Gray"
                               IsHitTestVisible="False"
                               Margin="5,2,0,0"
                               VerticalAlignment="Center">
						<TextBlock.Style>
							<Style TargetType="TextBlock">
								<Setter Property="Visibility" Value="Hidden"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding Text, ElementName=NewExtTextBox}" Value="">
										<Setter Property="Visibility" Value="Visible"/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</TextBlock.Style>
					</TextBlock>
				</Grid>

				<Button Grid.Column="1" Content="Add" Command="{Binding AddExtensionCommand}" Width="60" Margin="0,0,4,0"/>

				<Button Grid.Column="2" Content="Remove" Command="{Binding RemoveExtensionCommand}" Width="60"
                        CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
			</Grid>
		</Grid>

		<StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
			<Button Content="Save" Command="{Binding SaveSettingsCommand}" Width="80"/>
		</StackPanel>

	</Grid>
</Window>