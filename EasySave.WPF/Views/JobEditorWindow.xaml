<Window x:Class="EasySave.WPF.Views.JobEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding L[job.editor.title]}"
        SizeToContent="Height"
        Width="520"
        MinHeight="300"
        MaxHeight="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F0F4F0">

    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2E7D32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="BorderBrush" Value="#A5D6A7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F5E9"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8E6C9"/>
                    <Setter Property="Foreground" Value="#1B5E20"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B5E20"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#A5D6A7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2E7D32"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#2E7D32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8F5E9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1B5E20">
            <TextBlock Text="{Binding L[job.editor.title]}" Foreground="White"
                       FontSize="16" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="20,0"/>
        </Border>

        <!-- Form — wrapped in ScrollViewer so all fields remain accessible regardless of window height -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,4,0">
            <Grid Margin="24,20,24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="145"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Name -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding L[job.field.name]}"
                           Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Style="{StaticResource FormTextBox}"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Source path -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="{Binding L[job.field.source]}"
                           Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Style="{StaticResource FormTextBox}"
                         Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Target path -->
                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="{Binding L[job.field.target]}"
                           Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="4" Grid.Column="1"
                         Style="{StaticResource FormTextBox}"
                         Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Backup type — SelectedIndex maps to TypeIndex (0 = Full, 1 = Differential) -->
                <TextBlock Grid.Row="6" Grid.Column="0"
                           Text="{Binding L[job.field.type]}"
                           Style="{StaticResource FormLabel}"/>
                <ComboBox Grid.Row="6" Grid.Column="1"
                          Background="White" BorderBrush="#A5D6A7"
                          Padding="10,8" FontSize="13"
                          SelectedIndex="{Binding TypeIndex}">
                    <ComboBoxItem Content="{Binding L[job.type.full]}"/>
                    <ComboBoxItem Content="{Binding L[job.type.differential]}"/>
                </ComboBox>
            </Grid>
        </ScrollViewer>

        <!-- Footer buttons -->
        <Border Grid.Row="2" Background="White" BorderBrush="#C8E6C9" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="20,0">
                <Button Content="{Binding L[btn.cancel]}"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
                <Button Content="{Binding L[btn.save]}"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
