<Window x:Class="EasySave.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:EasySave.WPF.Localization"
        Title="{Binding L[app.title]}" Height="700" Width="1050"
        MinHeight="500" MinWidth="700"
        Background="#F0F4F0"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <loc:BindingProxy x:Key="Proxy" Data="{Binding}"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B5E20"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#145214"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#A5D6A7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PauseButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#F57F17"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E65100"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFCC80"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#C62828"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B71C1C"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#EF9A9A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#C62828"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B71C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#2E7D32"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#2E7D32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8F5E9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F5F5F5"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="BorderBrush" Value="#C8E6C9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E8F5E9"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F1F8F1"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="BorderBrush" Value="#1B5E20"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="#212121"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8E6C9"/>
                    <Setter Property="Foreground" Value="#1B5E20"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F5E9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="55"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1B5E20">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="38" Height="38" Background="White" CornerRadius="8" Margin="0,0,14,0">
                        <TextBlock Text="ES" FontWeight="Bold" FontSize="15"
                                   Foreground="#2E7D32" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="EasySave" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="v3.0 — ProSoft" FontSize="11" Foreground="#A5D6A7"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="Parallel · Priority · Pause/Resume/Stop"
                           Foreground="#81C784" FontSize="11" FontStyle="Italic"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- TOOLBAR ROW 1 — Job management + settings -->
        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#C8E6C9" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <Button Content="{Binding L[btn.run.all]}"  Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartAllCommand}"/>
                <Separator Background="#C8E6C9" Width="1" Height="26" Margin="6,0"/>
                <Button Content="{Binding L[btn.add]}"    Style="{StaticResource SecondaryButton}"
                        Command="{Binding AddJobCommand}"/>
                <Button Content="{Binding L[btn.edit]}"   Style="{StaticResource SecondaryButton}"
                        Command="{Binding EditJobCommand}"/>
                <Button Content="{Binding L[btn.delete]}" Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteJobCommand}"/>
                <Separator Background="#C8E6C9" Width="1" Height="26" Margin="6,0"/>
                <Button Content="{Binding L[btn.settings]}" Style="{StaticResource SecondaryButton}"
                        Command="{Binding OpenSettingsCommand}"/>
            </StackPanel>
        </Border>

        <!-- TOOLBAR ROW 2 — Global Pause / Resume / Stop (NEW v3.0) -->
        <Border Grid.Row="2" Background="#F8FFF8" BorderBrush="#C8E6C9" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="{Binding L[toolbar.all.jobs]}" Foreground="#5F5E5A" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button Content="{Binding L[btn.pause.all]}"  Style="{StaticResource PauseButton}"
                        Command="{Binding PauseAllCommand}"/>
                <Button Content="{Binding L[btn.resume.all]}" Style="{StaticResource PrimaryButton}"
                        Command="{Binding ResumeAllCommand}"/>
                <Button Content="{Binding L[btn.stop.all]}"   Style="{StaticResource StopButton}"
                        Command="{Binding StopAllCommand}"/>
                <ProgressBar Width="120" Height="5" HorizontalAlignment="Left"
                             IsIndeterminate="True" Foreground="#2E7D32" Background="#C8E6C9"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- DATAGRID -->
        <DataGrid Grid.Row="3" Margin="16"
                  ItemsSource="{Binding Jobs}"
                  SelectedItem="{Binding SelectedJob}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  CanUserResizeRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{Binding Data.L[col.name], Source={StaticResource Proxy}}"
                                    Binding="{Binding Name}" Width="160"/>
                <DataGridTextColumn Header="{Binding Data.L[col.source], Source={StaticResource Proxy}}"
                                    Binding="{Binding SourcePath}" Width="*"/>
                <DataGridTextColumn Header="{Binding Data.L[col.target], Source={StaticResource Proxy}}"
                                    Binding="{Binding TargetPath}" Width="*"/>
                <DataGridTextColumn Header="{Binding Data.L[col.status], Source={StaticResource Proxy}}"
                                    Binding="{Binding Status}" Width="90"/>
                <!-- Progress column -->
                <DataGridTemplateColumn Header="{Binding Data.L[col.progress], Source={StaticResource Proxy}}"
                                        Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="6,4">
                                <ProgressBar Value="{Binding ProgressPercent}" Maximum="100"
                                             Height="8" Background="#E8F5E9" Foreground="#2E7D32"/>
                                <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:F0}%}"
                                           HorizontalAlignment="Center" FontSize="10"
                                           Foreground="#1B5E20" Margin="0,12,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- Per-job control buttons (NEW v3.0) -->
                <DataGridTemplateColumn Header="{Binding Data.L[col.actions], Source={StaticResource Proxy}}"
                                        Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,3">
                                <Button Content="▶" ToolTip="Run"
                                        Command="{Binding RunCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="8,5" Margin="2,0" FontSize="11"/>
                                <Button Content="⏸" ToolTip="Pause"
                                        Command="{Binding PauseCommand}"
                                        Style="{StaticResource PauseButton}"
                                        Padding="8,5" Margin="2,0" FontSize="11"/>
                                <Button Content="⏵" ToolTip="Resume"
                                        Command="{Binding ResumeCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="8,5" Margin="2,0" FontSize="11"/>
                                <Button Content="⏹" ToolTip="Stop"
                                        Command="{Binding StopCommand}"
                                        Style="{StaticResource StopButton}"
                                        Padding="8,5" Margin="2,0" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- STATUS BAR -->
        <Border Grid.Row="4" Background="#1B5E20">
            <Grid Margin="16,0">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#A5D6A7" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
